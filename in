                title.innerText = rIdx === bracket.length - 1 ? 'Final' : `Round ${rIdx + 1}`;
                roundDiv.appendChild(title);
                round.forEach((m, mIdx) => {
                    const matchDiv = document.createElement('div');
                    matchDiv.id = `m-${rIdx}-${mIdx}`; matchDiv.className = 'match-card';
                    matchDiv.appendChild(createSlot(rIdx, mIdx, m.t1, m.win));
                    matchDiv.appendChild(createSlot(rIdx, mIdx, m.t2, m.win));
                    roundDiv.appendChild(matchDiv);
                });
                container.appendChild(roundDiv);
            });
            setTimeout(drawLines, 50);
        }

        function createSlot(rIdx, mIdx, team, winner) {
            const div = document.createElement('div');
            const isW = winner && team && winner.id === team.id;
            const isL = winner && team && winner.id !== team.id;
            div.className = `team-slot ${isW ? 'winner' : isL ? 'loser' : ''} ${!team ? 'empty' : ''}`;
            div.onclick = () => { if (team) { bracket[rIdx][mIdx].win = team; let r = rIdx+1, m = Math.floor(mIdx/2), isT1 = (mIdx % 2 === 0); while (r < bracket.length) { const target = bracket[r][m]; const oldId = isT1 ? target.t1?.id : target.t2?.id; if (isT1) target.t1 = team; else target.t2 = team; if (oldId !== team.id) target.win = null; else break; isT1 = (m % 2 === 0); m = Math.floor(m/2); r++; } if (rIdx === bracket.length - 1) showChamp(team); renderBracket(); } };
            if (team) div.innerHTML = `<img src="${team.logo}" class="team-logo" /><span class="truncate">${team.name}</span>`;
            else div.innerHTML = `<span class="opacity-20 text-xs font-bold uppercase tracking-widest">TBD</span>`;
            return div;
        }

        function showChamp(team) { document.getElementById('champ-name').innerText = team.name; document.getElementById('champ-img').src = team.logo; document.getElementById('champ-overlay').classList.add('active'); }
        function closeChamp() { document.getElementById('champ-overlay').classList.remove('active'); }
        function updateSettings(k, v) { settings[k] = parseInt(v); document.getElementById(`val-${k}`).innerText = v; renderBracket(); }
        function showInput() { document.getElementById('bracket-section').classList.add('hidden'); document.getElementById('input-section').classList.remove('hidden'); }

        function drawLines() {
            const svg = document.getElementById('svg-layer'); const cont = document.getElementById('bracket-container');
            if (!svg || !cont) return; const rect = cont.getBoundingClientRect();
            svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`); svg.innerHTML = '';
            for (let r = 0; r < bracket.length - 1; r++) {
                bracket[r].forEach((m, i) => {
                    const start = document.getElementById(`m-${r}-${i}`); const end = document.getElementById(`m-${r+1}-${Math.floor(i/2)}`);
                    if (start && end) {
                        const s = start.getBoundingClientRect(); const e = end.getBoundingClientRect();
                        const x1 = s.right - rect.left, y1 = s.top + s.height/2 - rect.top, x2 = e.left - rect.left, y2 = e.top + e.height/2 - rect.top;
