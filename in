                        path.setAttribute('d', `M ${x1} ${y1} L ${mid} ${y1} L ${mid} ${y2} L ${x2} ${y2}`); path.setAttribute('class', `path ${m.win ? 'active' : ''}`); svg.appendChild(path);
                    }
                });
            }
        }
