<body class="min-h-screen">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        function App() {
            const [teams, setTeams] = useState([
                "ทีมอาสากู้ภัย", "มังกรทอง FC", "สิงห์คะนองนา", "อินทรีเหล็ก Esports", "ฉลามชล Gaming", "พยัคฆ์ร้ายสายน้ำ", "หงส์แดง มหาอุด"
            ]);
            const [inputValue, setInputValue] = useState("");
            const [bracket, setBracket] = useState(null);
            const [mode, setMode] = useState('input'); // 'input' or 'bracket'

            const generateBracket = () => {
                if (teams.length < 2) return;
                const shuffled = [...teams].sort(() => Math.random() - 0.5);
                const n = shuffled.length;
                const nextPowerOfTwo = Math.pow(2, Math.ceil(Math.log2(n)));
                const spots = new Array(nextPowerOfTwo).fill(null);
                for (let i = 0; i < n; i++) spots[i] = shuffled[i];

                const rounds = [];
                const r1Matches = [];
                for (let i = 0; i < nextPowerOfTwo; i += 2) {
                    const t1 = spots[i];
                    const t2 = spots[i+1];
                    let winner = null;
                    if (t1 && !t2) winner = t1;
                    else if (!t1 && t2) winner = t2;
                    r1Matches.push({ id: `r0-m${i/2}`, team1: t1, team2: t2, winner });
                }
                rounds.push(r1Matches);

                let matchesInRound = nextPowerOfTwo / 4;
                let rIdx = 1;
                while (matchesInRound >= 1) {
                    const roundMatches = [];
                    for (let i = 0; i < matchesInRound; i++) {
                        roundMatches.push({ id: `r${rIdx}-m${i}`, team1: null, team2: null, winner: null });
                    }
                    rounds.push(roundMatches);
                    matchesInRound /= 2;
                    rIdx++;
                }

                propagate(rounds);
                setBracket(rounds);
                setMode('bracket');
            };

            const propagate = (currentBracket) => {
                for (let r = 0; r < currentBracket.length - 1; r++) {
                    const currentRound = currentBracket[r];
                    const nextRound = currentBracket[r + 1];
                    currentRound.forEach((match, mIdx) => {
                        if (match.winner) {
                            const nextMatchIdx = Math.floor(mIdx / 2);
                            const isSlot1 = mIdx % 2 === 0;
                            if (isSlot1) nextRound[nextMatchIdx].team1 = match.winner;
                            else nextRound[nextMatchIdx].team2 = match.winner;
                        }
                    });
                }
            };

            const handleSelectWinner = (rIdx, mIdx, winner) => {
                if (!winner || !bracket) return;
                const newBracket = JSON.parse(JSON.stringify(bracket));
                const currentMatch = newBracket[rIdx][mIdx];
                if (currentMatch.winner === winner) return;
                currentMatch.winner = winner;
                
                let r = rIdx + 1;
                let targetMIdx = Math.floor(mIdx / 2);
                let isSlot1 = mIdx % 2 === 0;
                let currentWinner = winner;

                while (r < newBracket.length) {
                    const targetMatch = newBracket[r][targetMIdx];
                    const oldTeam = isSlot1 ? targetMatch.team1 : targetMatch.team2;
                    if (isSlot1) targetMatch.team1 = currentWinner;
                    else targetMatch.team2 = currentWinner;
                    if (oldTeam !== currentWinner) {
                        targetMatch.winner = null;
                    } else break;
                    isSlot1 = targetMIdx % 2 === 0;
                    targetMIdx = Math.floor(targetMIdx / 2);
                    r++;
                }
                setBracket(newBracket);
            };

            const addTeam = () => {
                if (inputValue.trim() && teams.length < 32) {
                    setTeams([...teams, inputValue.trim()]);
                    setInputValue("");
                }
            };

            const removeTeam = (index) => setTeams(teams.filter((_, i) => i !== index));

            return (
                <div className="min-h-screen flex flex-col pb-20">
                    <header className="sticky top-0 z-50 glass border-b border-border px-8 py-4 mb-12">
                        <div className="max-w-[1600px] mx-auto flex justify-between items-center">
                            <div className="flex items-center gap-4">
                                <div className="w-12 h-12 bg-white rounded-xl border-2 border-[oklch(68%_0.23_145)] flex items-center justify-center font-black text-[oklch(68%_0.23_145)] text-xl">ISA</div>
                                <div>
                                    <h1 className="text-2xl font-black tracking-tight leading-none mb-1">ISA <span className="text-[oklch(68%_0.23_145)]">ESPORT</span></h1>
                                    <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Islamsriayuttha Foundation School</p>
                                </div>
                            </div>
                            {mode === 'bracket' && (
                                <button onClick={() => setMode('input')} className="px-6 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-bold transition-colors flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                                    แก้ไขรายชื่อทีม
                                </button>
                            )}
                        </div>
                    </header>

                    <main className="px-8 flex-1 max-w-[1600px] mx-auto w-full">
                        {mode === 'input' ? (
                            <div className="grid grid-cols-1 lg:grid-cols-12 gap-12 animate-slide-in">
                                <div className="lg:col-span-5 space-y-8">
                                    <div className="glass p-8 rounded-3xl shadow-2xl">
                                        <h2 className="text-2xl font-black mb-6 flex items-center gap-3">
                                            <span className="w-2 h-8 bg-[oklch(68%_0.23_145)] rounded-full"></span>
                                            จัดการรายชื่อทีม
                                        </h2>
                                        <div className="flex gap-3 mb-8">
                                            <input type="text" value={inputValue} onChange={(e) => setInputValue(e.target.value)} onKeyPress={(e) => e.key === 'Enter' && addTeam()} placeholder="ชื่อทีม..." className="flex-1 px-5 py-4 rounded-2xl border-2 border-border focus:border-[oklch(68%_0.23_145)] focus:outline-none transition-all font-bold text-lg" />
                                            <button onClick={addTeam} className="btn-primary px-8 rounded-2xl font-black text-lg">เพิ่ม</button>
                                        </div>
                                        <div className="space-y-3 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar">
                                            {teams.map((team, i) => (
                                                <div key={i} className="flex items-center justify-between p-4 bg-white rounded-2xl border border-border group hover:border-[oklch(68%_0.23_145)] shadow-sm">
                                                    <div className="flex items-center gap-4">
                                                        <span className="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-xs font-black text-slate-400">{i + 1}</span>
                                                        <span className="font-black text-slate-700 text-lg">{team}</span>
                                                    </div>
                                                    <button onClick={() => removeTeam(i)} className="text-slate-300 hover:text-red-500 p-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>
                                                </div>
                                            ))}
                                            {teams.length === 0 && <div className="text-center py-20 text-slate-400 font-bold italic border-2 border-dashed border-slate-200 rounded-3xl">ยังไม่มีทีมในรายการ (ขั้นต่ำ 2 ทีม)</div>}
                                        </div>
                                        <div className="mt-8 flex justify-between items-center text-sm font-black text-slate-400 uppercase tracking-widest">
                                            <span>รวม {teams.length} ทีม</span>
                                            {teams.length > 0 && <button onClick={() => setTeams([])} className="text-red-400 hover:text-red-600">ล้างทั้งหมด</button>}
                                        </div>
                                    </div>
                                </div>
                                <div className="lg:col-span-7 flex flex-col justify-center items-center text-center py-20 px-12 glass rounded-3xl border-dashed border-4 border-slate-200 bg-white/30">
                                    <div className="relative mb-10">
                                        <div className="absolute -inset-4 bg-[oklch(68%_0.23_145)]/20 rounded-full blur-2xl"></div>
                                        <div className="relative w-32 h-32 bg-[oklch(68%_0.23_145)] rounded-3xl flex items-center justify-center text-white rotate-6 shadow-xl">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
                                        </div>
                                    </div>
                                    <h3 className="text-4xl font-black mb-4">พร้อมเริ่มการแข่งขัน?</h3>
                                    <p className="text-slate-500 mb-12 max-w-md text-lg font-medium">ระบบจะทำการสุ่มทีมและจัดสายการแข่งขันแบบแพ้คัดออก (Single Elimination) ให้อัตโนมัติ</p>
                                    <button onClick={generateBracket} disabled={teams.length < 2} className={`btn-primary px-16 py-6 rounded-3xl font-black text-2xl flex items-center gap-4 ${teams.length < 2 ? 'opacity-50 grayscale' : ''}`}>สร้างสายการแข่งขัน <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="4" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></button>
                                </div>
                            </div>
                        ) : (
                            <div className="animate-slide-in overflow-x-auto pb-20 custom-scrollbar">
                                <div className="flex gap-24 min-w-max px-12 py-10 items-center justify-center">
                                    {bracket.map((round, rIdx) => (
                                        <div key={rIdx} className="flex flex-col justify-around gap-12" style={{ width: '280px' }}>
                                            <div className="text-center mb-6"><span className="px-4 py-1.5 bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-full">{rIdx === bracket.length - 1 ? "ชิงชนะเลิศ" : `รอบที่ ${rIdx + 1}`}</span></div>
                                            {round.map((match, mIdx) => (
                                                <div key={match.id} className="relative group">
                                                    <div className="flex flex-col gap-1.5">
                                                        <div onClick={() => handleSelectWinner(rIdx, mIdx, match.team1)} className={`team-node p-4 rounded-2xl border-2 text-base font-black flex justify-between items-center cursor-pointer glass ${!match.team1 ? 'empty' : ''} ${match.winner === match.team1 && match.team1 ? 'winner' : 'text-slate-700 bg-white/80'}`}>
                                                            <span className="truncate">{match.team1 || "???"}</span>
                                                            {match.winner === match.team1 && match.team1 && <div className="bg-white/20 p-1 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="4" strokeLinecap="round" strokeLinejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>}
                                                        </div>
                                                        <div className="flex items-center justify-center -my-3 z-20"><div className="bg-slate-50 border border-border px-2 py-0.5 rounded-md text-[8px] font-black text-slate-300 uppercase italic">VS</div></div>
                                                        <div onClick={() => handleSelectWinner(rIdx, mIdx, match.team2)} className={`team-node p-4 rounded-2xl border-2 text-base font-black flex justify-between items-center cursor-pointer glass ${!match.team2 ? 'empty' : ''} ${match.winner === match.team2 && match.team2 ? 'winner' : 'text-slate-700 bg-white/80'}`}>
                                                            <span className="truncate">{match.team2 || "???"}</span>
                                                            {match.winner === match.team2 && match.team2 && <div className="bg-white/20 p-1 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="4" strokeLinecap="round" strokeLinejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>}
                                                        </div>
                                                    </div>
                                                    {rIdx < bracket.length - 1 && (
                                                        <div className="absolute left-full top-1/2 -translate-y-1/2 flex items-center pointer-events-none">
                                                            <div className="h-[2px] w-12 bg-border opacity-40"></div>
                                                            <div className="w-[2px] bg-border opacity-40" style={{ height: 'calc(100% + 48px + 12px)', position: 'absolute', left: '48px', top: mIdx % 2 === 0 ? '50%' : 'auto', bottom: mIdx % 2 !== 0 ? '50%' : 'auto' }}></div>
                                                        </div>
                                                    )}
                                                </div>
                                            ))}
                                        </div>
                                    ))}
                                    <div className="flex flex-col justify-center items-center gap-8 ml-12" style={{ width: '320px' }}>
                                        <div className="text-center mb-4"><span className="px-6 py-2 bg-[oklch(68%_0.23_145)] text-white text-xs font-black uppercase tracking-[0.3em] rounded-full shadow-lg">ชนะเลิศ</span></div>
                                        <div className="relative group">
                                            <div className="absolute -inset-4 bg-[oklch(68%_0.23_145)] rounded-full blur-3xl opacity-20"></div>
                                            <div className="relative px-12 py-10 glass rounded-[2.5rem] border-4 border-[oklch(68%_0.23_145)] text-center min-w-[280px] shadow-2xl">
