                <button onclick="window.print()" class="bg-white border-2 border-slate-200 px-8 py-3 rounded-2xl font-bold hover:bg-slate-50 transition-colors">พิมพ์ / บันทึก PDF</button>
            </div>
            
            <div class="relative overflow-x-auto pb-20">
                <svg id="bracket-svg"></svg>
                <div id="bracket-container" class="flex gap-24 px-10 items-center justify-center min-w-max">
                    <!-- Rounds and matches will be injected here -->
                </div>
            </div>
        </div>
    </div>

    <script>
        const state = {
            teams: ["มังกรทอง FC", "สิงห์คะนองนา", "อินทรีเหล็ก Esports", "ฉลามชล Gaming", "พยัคฆ์ร้ายสายน้ำ", "หงส์แดง มหาอุด"],
            bracket: null
        };

        const inputEl = document.getElementById('team-input');
        const listEl = document.getElementById('team-list');
        const btnAdd = document.getElementById('btn-add');
        const btnGenerate = document.getElementById('btn-generate');
        const btnBack = document.getElementById('btn-back');
        const viewInput = document.getElementById('view-input');
        const viewBracket = document.getElementById('view-bracket');
        const bracketContainer = document.getElementById('bracket-container');
        const bracketSvg = document.getElementById('bracket-svg');

        function renderTeamList() {
            listEl.innerHTML = state.teams.map((t, i) => `
                <div class="bg-white border p-4 rounded-xl flex justify-between shadow-sm animate-pop">
                    <span class="font-bold">${i+1}. ${t}</span>
                    <button onclick="removeTeam(${i})" class="text-slate-300 hover:text-red-500 font-bold transition-colors">ลบ</button>
                </div>
            `).join('');
            btnGenerate.disabled = state.teams.length < 2;
        }

        function removeTeam(index) {
            state.teams.splice(index, 1);
            renderTeamList();
        }

        btnAdd.onclick = () => {
            if (inputEl.value.trim()) {
                state.teams.push(inputEl.value.trim());
                inputEl.value = '';
                renderTeamList();
            }
        };

        inputEl.onkeydown = (e) => { if (e.key === 'Enter') btnAdd.click(); };

        btnGenerate.onclick = () => {
            const shuffled = [...state.teams].sort(() => Math.random() - 0.5);
            const size = Math.pow(2, Math.ceil(Math.log2(shuffled.length)));
            const slots = new Array(size).fill(null);
            shuffled.forEach((t, i) => slots[i] = t);

            let rounds = [];
            let r1 = [];
            for (let i = 0; i < size; i += 2) {
                let t1 = slots[i], t2 = slots[i+1];
                let win = (t1 && !t2) ? t1 : (t2 && !t1) ? t2 : null;
                r1.push({ t1, t2, win });
            }
            rounds.push(r1);

            let nextCount = size / 4;
            while (nextCount >= 1) {
                let rd = [];
                for (let i = 0; i < nextCount; i++) rd.push({ t1: null, t2: null, win: null });
                rounds.push(rd);
                nextCount /= 2;
            }

            // Propagate byes
            for (let r = 0; r < rounds.length - 1; r++) {
                rounds[r].forEach((m, i) => {
                    if (m.win) {
                        let next = rounds[r+1][Math.floor(i/2)];
                        if (i % 2 === 0) next.t1 = m.win; else next.t2 = m.win;
                    }
                });
            }

            state.bracket = rounds;
            viewInput.classList.add('hidden');
            viewBracket.classList.remove('hidden');
            renderBracket();
        };

        btnBack.onclick = () => {
            viewBracket.classList.add('hidden');
            viewInput.classList.remove('hidden');
        };

        function renderBracket() {
            bracketContainer.innerHTML = state.bracket.map((round, rIdx) => `
                <div class="flex flex-col justify-around gap-12 h-full py-10">
                    <div class="text-center text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">
                        ${rIdx === state.bracket.length - 1 ? 'Championship' : 'Round ' + (rIdx + 1)}
                    </div>
                    ${round.map((m, mIdx) => `
                        <div id="match-${rIdx}-${mIdx}" class="match-card">
                            <div class="team-row ${m.win === m.t1 && m.win ? 'winner' : m.win ? 'loser' : ''} ${!m.t1 ? 'empty' : ''}" 
                                 onclick="pickWinner(${rIdx}, ${mIdx}, '${m.t1}')">
                                <span class="truncate">${m.t1 || 'WAITING...'}</span>
                            </div>
                            <div class="team-row ${m.win === m.t2 && m.win ? 'winner' : m.win ? 'loser' : ''} ${!m.t2 ? 'empty' : ''}" 
                                 onclick="pickWinner(${rIdx}, ${mIdx}, '${m.t2}')">
                                <span class="truncate">${m.t2 || 'WAITING...'}</span>
                            </div>
                        </div>
                    `).join('')}
                </div>
            `).join('');
            
            // Wait for DOM to settle then draw lines
            setTimeout(drawLines, 50);
        }

        function pickWinner(rIdx, mIdx, team) {
            if (!team || team === 'null' || team === 'undefined' || team === 'WAITING...') return;
            
            let bracket = state.bracket;
            bracket[rIdx][mIdx].win = team;
            
            let r = rIdx + 1, m = Math.floor(mIdx/2), isT1 = (mIdx % 2 === 0), val = team;
            while (r < bracket.length) {
                let target = bracket[r][m];
                let old = isT1 ? target.t1 : target.t2;
                if (isT1) target.t1 = val; else target.t2 = val;
                if (old !== val) target.win = null;
                isT1 = (m % 2 === 0); m = Math.floor(m/2); r++;
            }
            renderBracket();
        }

        function drawLines() {
            bracketSvg.innerHTML = '';
            const containerRect = bracketContainer.getBoundingClientRect();
            bracketSvg.setAttribute('viewBox', `0 0 ${containerRect.width} ${containerRect.height}`);
            
            for (let r = 0; r < state.bracket.length - 1; r++) {
                for (let m = 0; m < state.bracket[r].length; m++) {
                    const startEl = document.getElementById(`match-${r}-${m}`);
                    const nextMIdx = Math.floor(m / 2);
                    const endEl = document.getElementById(`match-${r+1}-${nextMIdx}`);
                    
                    if (startEl && endEl) {
                        const startRect = startEl.getBoundingClientRect();
                        const endRect = endEl.getBoundingClientRect();
                        
                        const x1 = (startRect.right - containerRect.left);
                        const y1 = (startRect.top + startRect.height/2 - containerRect.top);
                        const x2 = (endRect.left - containerRect.left);
                        const y2 = (endRect.top + endRect.height/2 - containerRect.top);
                        const midX = x1 + (x2 - x1) / 2;
                        
                        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                        path.setAttribute('d', `M ${x1} ${y1} L ${midX} ${y1} L ${midX} ${y2} L ${x2} ${y2}`);
                        path.setAttribute('class', 'connector-path');
                        bracketSvg.appendChild(path);
                    }
                }
            }
        }

        window.onresize = drawLines;
        renderTeamList();
    </script>
</body>
</html>


