            document.getElementById('team-count').innerText = teams.length;
            document.getElementById('start-btn').disabled = teams.length < 2;
        }

        function removeTeam(id) { teams = teams.filter(t => t.id !== id); renderTeams(); }

        function startBracket() {
            const shuffled = [...teams].sort(() => Math.random() - 0.5);
            const size = Math.pow(2, Math.ceil(Math.log2(shuffled.length)));
            const slots = new Array(size).fill(null);
            shuffled.forEach((t, i) => slots[i] = t);
            bracket = [];
            const r1 = [];
            for (let i = 0; i < size; i += 2) {
                let t1 = slots[i], t2 = slots[i+1];
                let win = (t1 && !t2) ? t1 : (t2 && !t1) ? t2 : null;
                r1.push({ t1, t2, win });
            }
            bracket.push(r1);
            let count = size / 4;
            while (count >= 1) {
                let rd = [];
                for (let i = 0; i < count; i++) rd.push({ t1: null, t2: null, win: null });
                bracket.push(rd);
                count /= 2;
            }
            propagate();
            document.getElementById('input-section').classList.add('hidden');
            document.getElementById('bracket-section').classList.remove('hidden');
            renderBracket();
        }

        function propagate() {
            for (let r = 0; r < bracket.length - 1; r++) {
                bracket[r].forEach((m, i) => { if (m.win) { const next = bracket[r+1][Math.floor(i/2)]; if (i % 2 === 0) next.t1 = m.win; else next.t2 = m.win; } });
