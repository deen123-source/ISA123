        const DEFAULT_LOGO = 'mpfk3fj8-image.png';
        let teams = [
            { id: 1, name: "สิงห์คะนองนา", logo: DEFAULT_LOGO }, { id: 2, name: "มังกรทอง FC", logo: DEFAULT_LOGO },
            { id: 3, name: "อินทรีเหล็ก Esports", logo: DEFAULT_LOGO }, { id: 4, name: "หงส์แดง มหาอุด", logo: DEFAULT_LOGO },
            { id: 5, name: "ฉลามชล Gaming", logo: DEFAULT_LOGO }, { id: 6, name: "พยัคฆ์ร้ายสายน้ำ", logo: DEFAULT_LOGO },
            { id: 7, name: "ยักษ์เขียว", logo: DEFAULT_LOGO }, { id: 8, name: "สายฟ้าแลบ", logo: DEFAULT_LOGO }
        ];
        let bracket = [];
        let currentLogo = null;
        let settings = { w: 240, g: 60, f: 16 };

        function previewLogo(input) {
