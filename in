            object-fit: cover;
            border: 1px solid var(--border);
            flex-shrink: 0;
        }

        .line-svg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        .path {
            fill: none;
            stroke: var(--border);
            stroke-width: 3;
            stroke-linecap: round;
        }

        .path.active {
            stroke: var(--isa-green);
            stroke-width: 5;
            filter: drop-shadow(0 0 5px var(--isa-green));
        }

        .champ-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
