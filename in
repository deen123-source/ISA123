                bracket[r].forEach((m, i) => {
                    if (m.win) {
                        const next = bracket[r+1][Math.floor(i/2)];
                        if (i % 2 === 0) next.t1 = m.win; else next.t2 = m.win;
                    }
                });
            }
        }

        function renderBracket() {
            const container = document.getElementById('bracket-container');
            container.style.setProperty('--match-width', `${settings.w}px`);
            container.style.setProperty('--match-gap', `${settings.g}px`);
            container.style.setProperty('--font-size', `${settings.f}px`);
            
            container.innerHTML = '<svg id="svg-layer" class="line-svg"></svg>';
            
            bracket.forEach((round, rIdx) => {
                const roundDiv = document.createElement('div');
                roundDiv.className = 'flex flex-col justify-around py-10';
                roundDiv.style.gap = `${settings.g}px`;
                roundDiv.style.minHeight = '800px';

                const title = document.createElement('h4');
                title.className = 'text-center text-[11px] font-black text-green-500 bg-green-50 px-4 py-1.5 rounded-full inline-block border border-green-100 uppercase tracking-widest mb-4';
                title.innerText = rIdx === bracket.length - 1 ? 'Championship' : `Round ${rIdx + 1}`;
                roundDiv.appendChild(title);

                round.forEach((m, mIdx) => {
                    const matchDiv = document.createElement('div');
                    matchDiv.id = `m-${rIdx}-${mIdx}`;
                    matchDiv.className = 'match-card';
                    matchDiv.appendChild(createTeamSlot(rIdx, mIdx, m.t1, m.win));
                    matchDiv.appendChild(createTeamSlot(rIdx, mIdx, m.t2, m.win));
                    roundDiv.appendChild(matchDiv);
                });
                container.appendChild(roundDiv);
            });
            setTimeout(drawLines, 50);
        }

        function createTeamSlot(rIdx, mIdx, team, winner) {
            const div = document.createElement('div');
            const isWin = winner && team && winner.id === team.id;
            const isLose = winner && team && winner.id !== team.id;
            div.className = `team-slot ${isWin ? 'winner' : ''} ${isLose ? 'loser' : ''} ${!team ? 'empty' : ''}`;
            div.onclick = () => pickWinner(rIdx, mIdx, team);
            if (team) {
                div.innerHTML = `<img src="${team.logo}" class="team-logo" /><span class="truncate">${team.name}</span>`;
            } else {
                div.innerHTML = `<span class="opacity-30">TBD</span>`;
            }
            return div;
        }

        function pickWinner(rIdx, mIdx, team) {
            if (!team || !bracket) return;
            bracket[rIdx][mIdx].win = team;
            let r = rIdx + 1, m = Math.floor(mIdx/2), isT1 = (mIdx % 2 === 0);
            while (r < bracket.length) {
                const target = bracket[r][m];
                const oldId = isT1 ? target.t1?.id : target.t2?.id;
                if (isT1) target.t1 = team; else target.t2 = team;
                if (oldId !== team.id) target.win = null; else break;
                isT1 = (m % 2 === 0); m = Math.floor(m/2); r++;
            }
            if (rIdx === bracket.length - 1) showChamp(team);
            renderBracket();
        }

        function showChamp(team) {
            document.getElementById('champ-name').innerText = team.name;
            document.getElementById('champ-img').src = team.logo;
            document.getElementById('champ-overlay').style.display = 'flex';
            setTimeout(() => document.getElementById('champ-overlay').classList.add('active'), 10);
        }

        function closeChamp() {
            const el = document.getElementById('champ-overlay');
            el.classList.remove('active');
            setTimeout(() => el.style.display = 'none', 500);
        }

        function updateSettings(key, val) {
            settings[key] = parseInt(val);
            document.getElementById(`val-${key}`).innerText = val;
            renderBracket();
        }

        function drawLines() {
            const svg = document.getElementById('svg-layer');
            const container = document.getElementById('bracket-container');
            if (!svg || !container) return;
            const rect = container.getBoundingClientRect();
            svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
            svg.innerHTML = '';

            for (let r = 0; r < bracket.length - 1; r++) {
                bracket[r].forEach((m, i) => {
                    const start = document.getElementById(`m-${r}-${i}`);
                    const end = document.getElementById(`m-${r+1}-${Math.floor(i/2)}`);
                    if (start && end) {
                        const s = start.getBoundingClientRect();
                        const e = end.getBoundingClientRect();
                        const x1 = s.right - rect.left, y1 = s.top + s.height/2 - rect.top;
                        const x2 = e.left - rect.left, y2 = e.top + e.height/2 - rect.top;
                        const mid = x1 + (x2 - x1) / 2;
                        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                        path.setAttribute('d', `M ${x1} ${y1} L ${mid} ${y1} L ${mid} ${y2} L ${x2} ${y2}`);
                        path.setAttribute('class', `path ${m.win ? 'active' : ''}`);
                        svg.appendChild(path);
                    }
                });
            }
        }

        function showInput() {
            document.getElementById('bracket-section').classList.add('hidden');
            document.getElementById('input-section').classList.remove('hidden');
        }

        renderTeams();
        window.addEventListener('resize', drawLines);
    </script>
</body>
</html>

