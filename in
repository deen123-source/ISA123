    <script>
        const DEFAULT_LOGO = 'mpfk3fj8-image.png';
        let teams = [
            { id: 1, name: "สิงห์คะนองนา", logo: DEFAULT_LOGO },
            { id: 2, name: "มังกรทอง FC", logo: DEFAULT_LOGO },
            { id: 3, name: "อินทรีเหล็ก Esports", logo: DEFAULT_LOGO },
            { id: 4, name: "หงส์แดง มหาอุด", logo: DEFAULT_LOGO },
            { id: 5, name: "ฉลามชล Gaming", logo: DEFAULT_LOGO },
            { id: 6, name: "พยัคฆ์ร้ายสายน้ำ", logo: DEFAULT_LOGO },
            { id: 7, name: "ยักษ์เขียว", logo: DEFAULT_LOGO },
            { id: 8, name: "สายฟ้าแลบ", logo: DEFAULT_LOGO }
        ];
        let bracket = [];
        let currentLogo = null;
        let settings = { w: 240, g: 60, f: 16 };

        function previewLogo(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    currentLogo = e.target.result;
                    document.getElementById('logo-preview').src = currentLogo;
                    document.getElementById('logo-preview').classList.remove('opacity-20');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function addTeam() {
            const name = document.getElementById('team-name').value.trim();
            if (name) {
                teams.push({ id: Date.now(), name, logo: currentLogo || DEFAULT_LOGO });
                document.getElementById('team-name').value = '';
                document.getElementById('logo-upload').value = '';
                document.getElementById('logo-preview').src = DEFAULT_LOGO;
                document.getElementById('logo-preview').classList.add('opacity-20');
                currentLogo = null;
                renderTeams();
            }
        }

        function removeTeam(id) {
            teams = teams.filter(t => t.id !== id);
            renderTeams();
        }

        function renderTeams() {
            const list = document.getElementById('teams-list');
            list.innerHTML = teams.map(t => `
                <div class="flex items-center justify-between p-4 bg-white rounded-2xl border-2 border-slate-50 shadow-sm hover:border-green-100 transition-all group">
                    <div class="flex items-center gap-4">
                        <img src="${t.logo}" class="w-10 h-10 rounded-full border bg-slate-50 object-cover" />
                        <span class="font-bold text-slate-700">${t.name}</span>
                    </div>
                    <button onclick="removeTeam(${t.id})" class="text-red-400 opacity-0 group-hover:opacity-100 transition-all font-black text-sm">ลบ</button>
                </div>
            `).join('');
            document.getElementById('team-count').innerText = teams.length;
            document.getElementById('start-btn').disabled = teams.length < 2;
        }

        function startBracket() {
            if (teams.length < 2) return;
            const shuffled = [...teams].sort(() => Math.random() - 0.5);
            const size = Math.pow(2, Math.ceil(Math.log2(shuffled.length)));
            const slots = new Array(size).fill(null);
            shuffled.forEach((t, i) => slots[i] = t);

            bracket = [];
            const r1 = [];
            for (let i = 0; i < size; i += 2) {
                let t1 = slots[i], t2 = slots[i+1];
                let win = (t1 && !t2) ? t1 : (t2 && !t1) ? t2 : null;
                r1.push({ t1, t2, win });
            }
            bracket.push(r1);

            let count = size / 4;
            while (count >= 1) {
                let rd = [];
                for (let i = 0; i < count; i++) rd.push({ t1: null, t2: null, win: null });
                bracket.push(rd);
                count /= 2;
            }

            propagate();
            document.getElementById('input-section').classList.add('hidden');
            document.getElementById('bracket-section').classList.remove('hidden');
            document.getElementById('bracket-section').classList.add('flex');
            renderBracket();
        }

        function propagate() {
            for (let r = 0; r < bracket.length - 1; r++) {
                bracket[r].forEach((m, i) => {
                    if (m.win) {
                        const next = bracket[r+1][Math.floor(i/2)];
                        if (i % 2 === 0) next.t1 = m.win; else next.t2 = m.win;
                    }
                });
            }
        }

        function renderBracket() {
            const container = document.getElementById('bracket-container');
            // Root variables for dynamic sizing
            container.style.setProperty('--match-width', `${settings.w}px`);
            container.style.setProperty('--match-gap', `${settings.g}px`);
            container.style.setProperty('--font-size', `${settings.f}px`);

            container.innerHTML = '<svg id="svg-layer" class="line-svg"></svg>';
            
            bracket.forEach((round, rIdx) => {
                const roundDiv = document.createElement('div');
                roundDiv.className = 'flex flex-col justify-around py-10';
                roundDiv.style.gap = `${settings.g}px`;
                roundDiv.style.minHeight = '900px';

                const title = document.createElement('h4');
                title.className = 'text-center text-[11px] font-black text-green-500 bg-green-50 px-4 py-1.5 rounded-full inline-block border border-green-100 uppercase tracking-widest mb-4';
                title.innerText = rIdx === bracket.length - 1 ? 'Championship' : `Round ${rIdx + 1}`;
                roundDiv.appendChild(title);

                round.forEach((m, mIdx) => {
                    const matchDiv = document.createElement('div');
                    matchDiv.id = `m-${rIdx}-${mIdx}`;
                    matchDiv.className = 'match-card';
                    
                    const t1Div = createTeamSlot(rIdx, mIdx, m.t1, m.win, 1);
                    const t2Div = createTeamSlot(rIdx, mIdx, m.t2, m.win, 2);
                    
                    matchDiv.appendChild(t1Div);
                    matchDiv.appendChild(t2Div);
                    roundDiv.appendChild(matchDiv);
                });
                container.appendChild(roundDiv);
            });

            setTimeout(drawLines, 100);
        }

        function createTeamSlot(rIdx, mIdx, team, winner, slotNum) {
            const div = document.createElement('div');
            const isWinner = winner && team && winner.id === team.id;
            const isLoser = winner && team && winner.id !== team.id;
            
            div.className = `team-slot ${isWinner ? 'winner' : ''} ${isLoser ? 'loser' : ''} ${!team ? 'empty' : ''}`;
            div.onclick = () => pickWinner(rIdx, mIdx, team);

            if (team) {
                div.innerHTML = `
                    <img src="${team.logo}" class="team-logo" />
                    <span class="truncate">${team.name}</span>
                `;
            } else {
                div.innerHTML = `<span class="opacity-30">TBD</span>`;
            }
            return div;
        }

        function pickWinner(rIdx, mIdx, team) {
            if (!team || !bracket) return;
            bracket[rIdx][mIdx].win = team;
            
            let r = rIdx + 1, m = Math.floor(mIdx/2), isT1 = (mIdx % 2 === 0);
            while (r < bracket.length) {
                const target = bracket[r][m];
                const old = isT1 ? target.t1?.id : target.t2?.id;
                if (isT1) target.t1 = team; else target.t2 = team;
                if (old !== team.id) target.win = null; else break;
                isT1 = (m % 2 === 0); m = Math.floor(m/2); r++;
            }
            
            if (rIdx === bracket.length - 1) {
                showChamp(team);
            }
            
            renderBracket();
        }

        function showChamp(team) {
            document.getElementById('champ-name').innerText = team.name;
            document.getElementById('champ-img').src = team.logo;
            document.getElementById('champ-overlay').classList.add('active');
        }

        function closeChamp() {
            document.getElementById('champ-overlay').classList.remove('active');
        }

        function updateSettings(key, val) {
            settings[key] = parseInt(val);
            document.getElementById(`val-${key}`).innerText = val;
            renderBracket();
        }

        function drawLines() {
            const svg = document.getElementById('svg-layer');
            if (!svg) return;
            const container = document.getElementById('bracket-container');
            const rect = container.getBoundingClientRect();
            
            svg.innerHTML = '';
            svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);

            for (let r = 0; r < bracket.length - 1; r++) {
                bracket[r].forEach((m, i) => {
                    const startEl = document.getElementById(`m-${r}-${i}`);
                    const endEl = document.getElementById(`m-${r+1}-${Math.floor(i/2)}`);
                    if (startEl && endEl) {
                        const s = startEl.getBoundingClientRect();
                        const e = endEl.getBoundingClientRect();
                        const x1 = s.right - rect.left;
                        const y1 = s.top + s.height/2 - rect.top;
                        const x2 = e.left - rect.left;
                        const y2 = e.top + e.height/2 - rect.top;
                        const mid = x1 + (x2 - x1) / 2;

                        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                        path.setAttribute('d', `M ${x1} ${y1} L ${mid} ${y1} L ${mid} ${y2} L ${x2} ${y2}`);
                        path.setAttribute('class', `path ${m.win ? 'active' : ''}`);
                        svg.appendChild(path);
                    }
                });
            }
        }

        function showInput() {
            document.getElementById('bracket-section').classList.add('hidden');
            document.getElementById('input-section').classList.remove('hidden');
        }

        // Init
        renderTeams();
        window.addEventListener('resize', drawLines);

    </script>
</body>
</html>


