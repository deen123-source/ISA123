                                            <div className="w-24 h-24 bg-white rounded-2xl border-2 border-border flex items-center justify-center overflow-hidden shadow-sm">
                                                {inputLogo ? <img src={inputLogo} className="w-full h-full object-cover" /> : <div className="text-slate-200"><svg width="40" height="40" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"/><polyline points="16 5 21 5 21 10"/><line x1="12" y1="12" x2="21" y2="3"/></svg></div>}
                                            </div>
                                            <div className="flex-1">
                                                <input type="file" id="logo-input" accept="image/*" onChange={handleLogoChange} className="hidden" />
                                                <label htmlFor="logo-input" className="cursor-pointer bg-white border-2 border-border px-4 py-2 rounded-xl text-sm font-bold hover:bg-slate-100 transition-colors inline-block mb-2">อัปโหลดรูปภาพ</label>
                                                <p className="text-[10px] text-slate-400">ถ้าไม่ได้ใส่ จะใช้โลโก้โรงเรียนแทน</p>
                                            </div>
                                        </div>
                                    </div>
                                    <button 
                                        className="w-full py-5 bg-slate-900 text-white font-black rounded-2xl hover:bg-black transition-all mt-6 text-xl shadow-xl active:scale-95"
                                        onClick={addTeam}
                                    >
                                        เพิ่มทีมเข้าร่วม
                                    </button>
                                </div>
                            </div>

                            {/* List Column */}
                            <div className="glass p-10 rounded-[2.5rem] shadow-2xl flex flex-col">
                                <div className="flex items-center justify-between mb-8">
                                    <h2 className="text-3xl font-black">ทีมทั้งหมด ({teams.length})</h2>
                                    <button onClick={() => setTeams([])} className="text-xs font-bold text-red-500 hover:bg-red-50 px-3 py-1 rounded-lg transition-colors">ล้างทั้งหมด</button>
                                </div>
                                <div className="flex-1 max-h-[450px] overflow-y-auto pr-2 custom-scrollbar space-y-3">
                                    {teams.map(t => (
