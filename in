                                    ข้อมูลทีม
                                </h2>
                                <div className="space-y-6">
                                    <div className="flex flex-col gap-3">
                                        <label className="text-sm font-black text-slate-400 uppercase tracking-widest">ชื่อทีม</label>
                                        <input 
                                            className="bg-white border-2 border-border p-5 rounded-2xl font-bold focus:border-[oklch(68%_0.23_145)] outline-none transition-all text-xl shadow-inner"
                                            value={inputName}
                                            onChange={e => setInputName(e.target.value)}
                                            onKeyDown={e => e.key === 'Enter' && addTeam()}
                                            placeholder="ใส่ชื่อทีมที่นี่..."
                                        />
                                    </div>
                                    <div className="flex flex-col gap-3">
                                        <label className="text-sm font-black text-slate-400 uppercase tracking-widest">โลโก้ทีม</label>
