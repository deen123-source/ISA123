    <script>
        // Pre-filled teams as requested to ensure immediate results
        let teams = ["สิงห์คะนองนา", "มังกรทอง FC", "อินทรีเหล็ก", "พยัคฆ์ร้าย", "ฉลามชล", "หงส์แดง มหาอุด", "อินทรี Esports", "สายฟ้าแลบ"];
        let bracket = [];

        function addT() {
            const input = document.getElementById('t-input');
            const val = input.value.trim();
            if(val) { teams.push(val); input.value = ''; renderList(); }
        }

        function renderList() {
            const list = document.getElementById('t-list');
            list.innerHTML = teams.map((t, i) => `
                <div style="display:flex; justify-content:space-between; align-items:center; background:#f8fafc; padding:12px 20px; border-radius:12px; border:1px solid #e2e8f0; margin-bottom:8px;">
                    <span style="font-weight:bold; color:#1e293b;">${i+1}. ${t}</span>
                    <button onclick="teams.splice(${i},1);renderList()" style="color:#f87171; border:none; background:none; cursor:pointer; font-weight:bold;">ลบออก</button>
                </div>
            `).join('');
        }

        function build() {
            if(teams.length < 2) { alert("กรุณาใส่ชื่อทีมอย่างน้อย 2 ทีม"); return; }
            const shuffled = [...teams].sort(() => Math.random() - 0.5);
            const size = Math.pow(2, Math.ceil(Math.log2(shuffled.length)));
            const slots = new Array(size).fill(null);
            shuffled.forEach((t, i) => slots[i] = t);

            bracket = [];
            let r1 = [];
            for (let i = 0; i < size; i += 2) {
                let t1 = slots[i], t2 = slots[i+1];
                let win = (t1 && !t2) ? t1 : (t2 && !t1) ? t2 : null;
                r1.push({ t1, t2, win });
            }
            bracket.push(r1);

            let n = size / 4;
            while(n >= 1) {
                let rd = [];
                for(let i=0; i<n; i++) rd.push({ t1: null, t2: null, win: null });
                bracket.push(rd);
                n /= 2;
            }

            propagate();
            document.getElementById('setup').style.display = 'none';
            document.getElementById('display').style.display = 'block';
            renderBracket();
        }

        function propagate() {
            for (let r = 0; r < bracket.length - 1; r++) {
                bracket[r].forEach((m, i) => {
                    if (m.win) {
                        let next = bracket[r+1][Math.floor(i/2)];
                        if (i % 2 === 0) next.t1 = m.win; else next.t2 = m.win;
                    }
                });
            }
        }

        function renderBracket() {
            const container = document.getElementById('container');
            container.innerHTML = bracket.map((round, rIdx) => `
                <div style="display:flex; flex-direction:column; justify-content:space-around; gap:40px; min-height:700px; padding: 20px 0;">
                    <div style="text-align:center; font-weight:900; color:#cbd5e1; text-transform:uppercase; letter-spacing:4px; font-size:11px;">
                        ${rIdx === bracket.length - 1 ? 'Championship' : 'Round ' + (rIdx + 1)}
                    </div>
                    ${round.map((m, mIdx) => `
                        <div id="m-${rIdx}-${mIdx}" class="match-card">
                            <div class="team-row ${m.win === m.t1 && m.win ? 'winner' : ''} ${!m.t1 ? 'empty' : ''}" onclick="pick(${rIdx}, ${mIdx}, '${m.t1}')">
                                <span>${m.t1 || 'WAITING...'}</span>
                                ${m.win === m.t1 && m.t1 ? '<span>✓</span>' : ''}
                            </div>
                            <div class="team-row ${m.win === m.t2 && m.win ? 'winner' : ''} ${!m.t2 ? 'empty' : ''}" onclick="pick(${rIdx}, ${mIdx}, '${m.t2}')">
                                <span>${m.t2 || 'WAITING...'}</span>
                                ${m.win === m.t2 && m.t2 ? '<span>✓</span>' : ''}
                            </div>
                        </div>
                    `).join('')}
                </div>
            `).join('');
            setTimeout(drawLines, 200);
        }

        function pick(rIdx, mIdx, team) {
            if(!team || team === 'null' || team === 'WAITING...') return;
            bracket[rIdx][mIdx].win = team;
            let r = rIdx + 1, m = Math.floor(mIdx/2), isT1 = (mIdx % 2 === 0), val = team;
            while (r < bracket.length) {
                let target = bracket[r][m];
                let old = isT1 ? target.t1 : target.t2;
                if (isT1) target.t1 = val; else target.t2 = val;
                if (old !== val) target.win = null;
                isT1 = (m % 2 === 0); m = Math.floor(m/2); r++;
            }
            renderBracket();
        }

        function drawLines() {
            const svg = document.getElementById('bracket-svg');
            svg.innerHTML = '';
            const container = document.getElementById('container');
            const rect = container.getBoundingClientRect();
            svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
            
            for (let r = 0; r < bracket.length - 1; r++) {
                for (let m = 0; m < bracket[r].length; m++) {
                    const startEl = document.getElementById(`m-${r}-${m}`);
                    const endEl = document.getElementById(`m-${r+1}-${Math.floor(m/2)}`);
                    if(!startEl || !endEl) continue;
                    
                    const s = startEl.getBoundingClientRect();
                    const e = endEl.getBoundingClientRect();
                    
                    const x1 = s.right - rect.left;
                    const y1 = s.top + s.height/2 - rect.top;
                    const x2 = e.left - rect.left;
                    const y2 = e.top + e.height/2 - rect.top;
                    
                    const mx = x1 + (x2 - x1) / 2;
                    
                    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                    path.setAttribute('d', `M ${x1} ${y1} L ${mx} ${y1} L ${mx} ${y2} L ${x2} ${y2}`);
                    path.setAttribute('class', 'line');
                    svg.appendChild(path);
                }
            }
        }

        function reset() {
            document.getElementById('display').style.display = 'none';
            document.getElementById('setup').style.display = 'block';
        }

        // Initialize
        renderList();
        window.addEventListener('resize', drawLines);
    </script>
