            ]);
            const [inputName, setInputName] = useState("");
            const [inputLogo, setInputLogo] = useState(null);
            const [bracket, setBracket] = useState(null);
            const [mode, setMode] = useState('input');
            const [settings, setSettings] = useState({
                cardWidth: 240,
                verticalGap: 60,
                fontSize: 16
            });
            const [champion, setChampion] = useState(null);
            const containerRef = useRef(null);
            const [svgLines, setSvgLines] = useState([]);

            const handleLogoChange = (e) => {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onloadend = () => setInputLogo(reader.result);
                    reader.readAsDataURL(file);
                }
            };

            const addTeam = () => {
                if (inputName.trim()) {
                    setTeams([...teams, { 
                        id: Date.now(), 
                        name: inputName.trim(), 
                        logo: inputLogo || "mpfk3fj8-image.png" 
                    }]);
                    setInputName("");
                    setInputLogo(null);
                }
            };

            const removeTeam = (id) => setTeams(teams.filter(t => t.id !== id));

            const startTournament = () => {
                if (teams.length < 2) return;
                const shuffled = [...teams].sort(() => Math.random() - 0.5);
                const size = Math.pow(2, Math.ceil(Math.log2(shuffled.length)));
                const spots = new Array(size).fill(null);
                shuffled.forEach((t, i) => spots[i] = t);

                const rounds = [];
                const r1 = [];
                for (let i = 0; i < size; i += 2) {
                    let t1 = slots[i], t2 = slots[i+1];
                    let win = (t1 && !t2) ? t1 : (t2 && !t1) ? t2 : null;
                    r1.push({ id: `r0-m${i/2}`, t1, t2, win });
                }
                rounds.push(r1);

                let nextCount = size / 4;
                while (nextCount >= 1) {
                    let rd = [];
                    for (let i = 0; i < nextCount; i++) rd.push({ id: `r${rounds.length}-m${i}`, t1: null, t2: null, win: null });
                    rounds.push(rd);
                    nextCount /= 2;
                }

                propagate(rounds);
                setBracket(rounds);
                setMode('bracket');
                setChampion(null);
            };

            const propagate = (b) => {
                for (let r = 0; r < b.length - 1; r++) {
                    b[r].forEach((m, i) => {
                        if (m.win) {
                            let next = b[r+1][Math.floor(i/2)];
                            if (i % 2 === 0) next.t1 = m.win; else next.t2 = m.win;
                        }
                    });
                }
            };

            const pickWinner = (rIdx, mIdx, team) => {
                if (!team || !bracket) return;
                const newB = JSON.parse(JSON.stringify(bracket));
                const currentMatch = newB[rIdx][mIdx];
                
                // If clicking the same winner, just ignore or deselect? Let's just set.
                currentMatch.win = team;

                let r = rIdx + 1;
                let m = Math.floor(mIdx/2);
                let isT1 = (mIdx % 2 === 0);
                let currentVal = team;

                // Propagate forward
                while (r < newB.length) {
                    let target = newB[r][m];
                    let oldId = isT1 ? (target.t1?.id) : (target.t2?.id);
                    
                    if (isT1) target.t1 = currentVal; else target.t2 = currentVal;
                    
                    // If the slot content actually changed, reset its winner
                    if (oldId !== currentVal.id) {
                        target.win = null;
                    } else break; // No more changes needed

                    isT1 = (m % 2 === 0);
                    m = Math.floor(m/2);
                    r++;
                }

                // If this was the final, set champion
                if (rIdx === newB.length - 1) {
                    setChampion(team);
                }

                setBracket(newB);
            };

            useEffect(() => {
                if (mode === 'bracket') {
                    const timer = setTimeout(drawLines, 300);
                    window.addEventListener('resize', drawLines);
                    return () => {
                        clearTimeout(timer);
                        window.removeEventListener('resize', drawLines);
                    }
                }
            }, [bracket, mode, settings]);

            const drawLines = () => {
                if (!containerRef.current || !bracket) return;
                const container = containerRef.current;
                const rect = container.getBoundingClientRect();
                const lines = [];

                for (let r = 0; r < bracket.length - 1; r++) {
                    for (let m = 0; m < bracket[r].length; m++) {
                        const startEl = document.getElementById(`m-${r}-${m}`);
